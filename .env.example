################################################################################
# EBS paper reproduction environment
#
# 1. Copy this file to `.env` before running an experiment.
# 2. Replace every `replace-me` value with a real credential.
# 3. Never commit `.env`; it is ignored by Git.
#
# Paper-aligned defaults:
# - target / rollout model: Qwen/Qwen3-8B
# - evaluation judge model: Qwen/Qwen3-14B
# - API protocol: OpenAI-compatible Chat Completions
#
# The example URLs below use SiliconFlow because the checked-in evaluation YAML
# uses that endpoint. You may replace them with any compatible hosted service or
# a local vLLM/SGLang endpoint without changing the EBS pipeline.
################################################################################


# ==============================================================================
# A. EBS agent model
# ==============================================================================
# Used when `ebs/train.py` or `ebs/main.py` runs with `--mode agent`.
# Keep this model aligned with the target model unless intentionally testing a
# different agent backbone.

EBS_LLM_TYPE=chat.completions
EBS_LLM_MODEL=Qwen/Qwen3-8B
EBS_LLM_BASE_URL=https://api.siliconflow.cn/v1
EBS_LLM_API_KEY=replace-me

# Per-request timeout in seconds for the EBS agent client.
EBS_LLM_TIMEOUT=3600


# ==============================================================================
# B. Target / rollout model
# ==============================================================================
# Used by experience generation (`ebs/train.py`), experience reuse
# (`ebs/main.py`), and the paper-facing evaluation scripts.
#
# These variables override the EBS_LLM_* rollout defaults. CLI arguments such as
# `--rollout_model`, `--target_model`, and `--target_base_url` take precedence
# when the corresponding script exposes them.

TARGET_LLM_MODEL=Qwen/Qwen3-8B
TARGET_LLM_BASE_URL=https://api.siliconflow.cn/v1
TARGET_LLM_API_KEY=replace-me
TARGET_LLM_TIMEOUT=3600


# ==============================================================================
# C. Judge for experience generation and simple reuse
# ==============================================================================
# Used by `ebs/core/verify.py` to score safety and usefulness during experience
# generation and by `ebs/main.py` when verification is enabled.

EBS_JUDGE_MODEL=Qwen/Qwen3-14B
EBS_JUDGE_BASE_URL=https://api.siliconflow.cn/v1
EBS_JUDGE_API_KEY=replace-me

# Per-request timeout in seconds for the generation/reuse judge.
EBS_JUDGE_TIMEOUT=3600


# ==============================================================================
# D. Judges for the paper main experiment
# ==============================================================================
# Read by `configs/eval/redeval_redbench.yaml`.
#
# ATTACK_JUDGE_API_KEY:
#   HarmBench unsafe-compliance / attack-success classification.
#
# OPENAI_API_KEY:
#   XSTest refusal classification and boundary-decision judging.
#
# The checked-in YAML uses Qwen/Qwen3-14B for both judge roles. The two variables
# may contain the same provider key, but they remain separate so each judge can
# be redirected independently in future experiments.

ATTACK_JUDGE_API_KEY=replace-me
OPENAI_API_KEY=replace-me


# ==============================================================================
# E. Dataset and runtime controls
# ==============================================================================
# Named datasets such as `xstest` and `harmbench` are resolved below this path by
# `ebs/core/dataset.py`. The paper main experiment reads
# `dataset/redbench_dataset.json` directly and does not require this override.

EBS_DATA_DIR=data/ebs/dataset

# OpenAI-compatible request timeout used by the RedBench evaluation adapter.
EBS_OPENAI_TIMEOUT_SECONDS=3600

# Recommended public-reproduction log level: DEBUG, INFO, WARNING, or ERROR.
EBS_LOG_LEVEL=INFO
